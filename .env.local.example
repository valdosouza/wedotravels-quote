# ============================================
# WeDo Travels - Quote System Configuration
# ============================================
# Rename this file to .env.local and fill in values

# WhatsApp number (Ireland format, no spaces, no +)
# Example: 353861234567
NEXT_PUBLIC_WHATSAPP_NUMBER=353861234567

# Email to receive quotes
NEXT_PUBLIC_QUOTE_EMAIL=quotes@wedotravels.ie

# Email sender configuration (for backup email)
# Option A: Using Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# Option B: Using Resend (recommended)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=quotes@wedotravels.ie
EMAIL_TO=your-email@wedotravels.ie
