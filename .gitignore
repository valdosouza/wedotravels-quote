# ============================================
# WeDo Travels – .gitignore
# ============================================

# ---- Dependências ----
node_modules/
.pnp
.pnp.js

# ---- Build / Output ----
.next/
out/
build/
dist/

# ---- Variáveis de ambiente (DADOS SENSÍVEIS) ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ---- Cache ----
.npm
.eslintcache
.cache/
*.tsbuildinfo
next-env.d.ts

# ---- Sistema operacional ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Editores / IDEs ----
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
.vs/

# ---- TypeScript ----
*.js.map
*.d.ts.map

# ---- Testes ----
/coverage
/.nyc_output

# ---- Misc ----
*.pem
*.key
*.cert
*.p12
